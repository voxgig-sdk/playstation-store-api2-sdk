{
  "openapi": "3.0.3",
  "info": {
    "title": "PlayStation Store API",
    "description": "The PlayStation Store API provides access to a wide array of PlayStation games and downloadable content. Users can retrieve detailed information on game types, pricing, release dates, and platform availability. This API is essential for developers looking to integrate PlayStation content into their applications or services.",
    "version": "1.0.0",
    "contact": {
      "name": "PlayStation Store",
      "url": "https://store.playstation.com"
    }
  },
  "servers": [
    {
      "url": "https://store.playstation.com/store/api/chihiro/00_09_000",
      "description": "PlayStation Store API Server"
    }
  ],
  "paths": {
    "/container/{country}/{language}/{age_limit}/{container_id}": {
      "get": {
        "summary": "Get container content",
        "description": "Retrieves a list of games and downloadable content from the PlayStation Store based on the specified container and filters.",
        "operationId": "getContainer",
        "parameters": [
          {
            "name": "country",
            "in": "path",
            "description": "Country code (e.g., 'ch' for Switzerland)",
            "required": true,
            "schema": {
              "type": "string",
              "example": "ch"
            }
          },
          {
            "name": "language",
            "in": "path",
            "description": "Language code (e.g., 'de' for German)",
            "required": true,
            "schema": {
              "type": "string",
              "example": "de"
            }
          },
          {
            "name": "age_limit",
            "in": "path",
            "description": "Age limit for content filtering",
            "required": true,
            "schema": {
              "type": "string",
              "example": "999"
            }
          },
          {
            "name": "container_id",
            "in": "path",
            "description": "Container identifier (e.g., 'STORE-MSF75508-FULLGAMES' for full games)",
            "required": true,
            "schema": {
              "type": "string",
              "example": "STORE-MSF75508-FULLGAMES"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Number of items to return per page",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Offset for pagination (starting index)",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order for results",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "release_date",
                "name",
                "price"
              ],
              "default": "release_date"
            }
          },
          {
            "name": "platform",
            "in": "query",
            "description": "Filter by platform (ps4, ps5, ps3, vita, psp)",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "ps4",
                "ps5",
                "ps3",
                "vita",
                "psp"
              ]
            }
          },
          {
            "name": "price",
            "in": "query",
            "description": "Filter by price range",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "0-249",
                "250-499",
                "500-999",
                "1000-1999",
                "2000-2999",
                "3000-3999",
                "4000-4999",
                "5000-5999",
                "6000-7999",
                "8000-*"
              ]
            }
          },
          {
            "name": "genre",
            "in": "query",
            "description": "Filter by game genre",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "action",
                "adventure",
                "arcade",
                "racing",
                "shooter",
                "sports",
                "rpg",
                "puzzle",
                "strategy",
                "simulation"
              ]
            }
          },
          {
            "name": "game_content_type",
            "in": "query",
            "description": "Filter by game content type",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "bundles",
                "games",
                "timed_trials"
              ]
            }
          },
          {
            "name": "release_date",
            "in": "query",
            "description": "Filter by release date range",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "coming_soon",
                "last_7_days",
                "last_30_days"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with container content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContainerResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Container not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "Container"
        ]
      }
    }
  },
